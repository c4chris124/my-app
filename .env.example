# ──────────────────────────────────────────────────────────────────────────
# REHOBOT — environment template. Copy to .env at the monorepo root:
#   cp .env.example .env
# POSTGRES_PASSWORD and SESSION_SECRET are REQUIRED (no defaults).
# ──────────────────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
PORT=3000

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-required

# ── Redis (session store) ──
REDIS_URL=redis://localhost:6379

# ── Session / cookies ──
# 32+ char random secret. Rotating it invalidates every cookie (global kill-switch).
#   openssl rand -base64 48
SESSION_SECRET=change-me-min-32-chars-rotate-to-revoke-all-sessions
SESSION_COOKIE_NAME=            # blank -> 'sid' (dev) / '__Host-sid' (prod)
CSRF_COOKIE_NAME=csrf
SESSION_IDLE_TTL=604800         # 7 days  (sliding idle timeout, seconds)
SESSION_ABSOLUTE_TTL=2592000    # 30 days (hard cap, seconds)
SESSION_MAX_PER_USER=10
SESSION_TOUCH_INTERVAL=60       # throttle last-seen writes (seconds)
COOKIE_SECURE=                  # blank -> true in prod, false in dev
COOKIE_SAMESITE=lax             # lax | strict | none
COOKIE_DOMAIN=                  # leave blank when using the __Host- prefix

# ── Password hashing (argon2id — OWASP defaults) ──
ARGON2_MEMORY_COST=19456        # KiB (19 MiB)
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
PASSWORD_PEPPER=                # optional server-side secret mixed into every hash

# ── Google OAuth 2.0 (optional) ──
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be browser-reachable and registered in Google Console. Route it through the
# SPA origin so the session cookie is set same-origin as the app:
#   dev:  http://localhost:5173/api/auth/google/callback
#   prod: https://app.example.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
OAUTH_STATE_TTL=300             # OAuth state cookie lifetime (seconds)
OAUTH_SUCCESS_REDIRECT=/
OAUTH_FAILURE_REDIRECT=/login?error=oauth
OAUTH_ALLOWED_RETURN_TO=/,/crm,/ecommerce,/account
